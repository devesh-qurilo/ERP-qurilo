NODE_ENV=development
JWT_SECRET=replace-me
INTERNAL_API_KEY=replace-me
AUTH_ADMIN_EMAILS=admin@example.com
GOOGLE_TRANSLATE_API_KEY=disabled

# Cloudinary
CLOUDINARY_CLOUD_NAME=replace-me
CLOUDINARY_API_KEY=replace-me
CLOUDINARY_API_SECRET=replace-me

# Local Docker Postgres
AUTH_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/erp_auth?schema=public
EMPLOYEE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/erp_employee?schema=public
CLIENT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/erp_client?schema=public
LEAD_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/erp_lead?schema=public
PROJECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/erp_project?schema=public
CHAT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/erp_chat?schema=public
FINANCE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/erp_finance?schema=public

# Service ports
GATEWAY_PORT=8080
AUTH_PORT=8081
EMPLOYEE_PORT=8083
CLIENT_PORT=8084
LEAD_PORT=8085
PROJECT_PORT=8086

# Service URLs
AUTH_SERVICE_URL=http://localhost:8081
EMPLOYEE_SERVICE_URL=http://localhost:8083
CLIENT_SERVICE_URL=http://localhost:8084
LEAD_SERVICE_URL=http://localhost:8085
PROJECT_SERVICE_URL=http://localhost:8086
CHAT_SERVICE_URL=http://localhost:8087
FINANCE_SERVICE_URL=http://localhost:8088
