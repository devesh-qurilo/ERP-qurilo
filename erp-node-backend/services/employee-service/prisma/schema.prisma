generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("EMPLOYEE_DATABASE_URL")
}

enum LeaveType {
  CASUAL
  SICK
  EARNED
}

enum DurationType {
  FULL_DAY
  MULTIPLE
  HALF_DAY
  SECOND_HALF
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model Department {
  id               BigInt       @id @default(autoincrement())
  departmentName   String       @unique @map("department_name")
  parentId         BigInt?      @map("parent_id")
  createdAt        DateTime     @default(now()) @map("created_at")
  parentDepartment Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  childDepartments Department[] @relation("DepartmentHierarchy")
  employees        Employee[]
  oldPromotions    Promotion[]  @relation("PromotionOldDepartment")
  newPromotions    Promotion[]  @relation("PromotionNewDepartment")

  @@map("departments")
}

model Designation {
  id                BigInt        @id @default(autoincrement())
  designationName   String        @unique @map("designation_name")
  parentId          BigInt?       @map("parent_designation_id")
  createdAt         DateTime      @default(now()) @map("created_at")
  parentDesignation Designation?  @relation("DesignationHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  childDesignations Designation[] @relation("DesignationHierarchy")
  employees         Employee[]
  oldPromotions     Promotion[]   @relation("PromotionOldDesignation")
  newPromotions     Promotion[]   @relation("PromotionNewDesignation")

  @@map("designations")
}

model Employee {
  employeeId                String       @id @map("employee_id")
  name                      String
  email                     String       @unique
  password                  String?
  profilePictureUrl         String?      @map("profile_picture_url")
  gender                    String?
  birthday                  DateTime?    @db.Date
  bloodGroup                String?      @map("blood_group")
  joiningDate               DateTime?    @map("joining_date") @db.Date
  language                  String?
  country                   String?
  mobile                    String?      @unique
  address                   String?
  about                     String?
  departmentId              BigInt?      @map("department_id")
  designationId             BigInt?      @map("designation_id")
  reportingToId             String?      @map("reporting_to_id")
  role                      String       @default("ROLE_EMPLOYEE")
  loginAllowed              Boolean      @default(true) @map("login_allowed")
  receiveEmailNotification  Boolean      @default(true) @map("receive_email_notification")
  hourlyRate                Float?       @map("hourly_rate")
  slackMemberId             String?      @map("slack_member_id")
  skills                    String[]
  probationEndDate          DateTime?    @map("probation_end_date") @db.Date
  noticePeriodStartDate     DateTime?    @map("notice_period_start_date") @db.Date
  noticePeriodEndDate       DateTime?    @map("notice_period_end_date") @db.Date
  employmentType            String?      @map("employment_type")
  maritalStatus             String?      @map("marital_status")
  businessAddress           String?      @map("business_address")
  officeShift               String?      @map("office_shift")
  active                    Boolean      @default(true)
  createdAt                 DateTime     @default(now()) @map("created_at")
  department                Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designation               Designation? @relation(fields: [designationId], references: [id], onDelete: SetNull)
  reportingTo               Employee?    @relation("EmployeeHierarchy", fields: [reportingToId], references: [employeeId], onDelete: SetNull)
  directReports             Employee[]   @relation("EmployeeHierarchy")
  attendances               Attendance[] @relation("EmployeeAttendance")
  markedAttendances         Attendance[] @relation("AttendanceMarkedBy")
  attendanceActivities      AttendanceActivity[]
  leaves                    Leave[]      @relation("EmployeeLeaves")
  approvedLeaves            Leave[]      @relation("LeaveApprovedBy")
  leaveQuotas               LeaveQuota[]
  emergencyContacts         EmergencyContact[]
  documents                 EmployeeDocument[]
  sentNotifications         Notification[]    @relation("NotificationSender")
  receivedNotifications     Notification[]    @relation("NotificationReceiver")
  pushTokens                PushToken[]
  appreciationsGiven        Appreciation[]
  promotions                Promotion[]

  @@map("employees")
}

model EmployeeInvite {
  id        BigInt   @id @default(autoincrement())
  employeeId String  @map("employee_id")
  email     String
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([employeeId], map: "idx_employee_invites_employee_id")
  @@index([email], map: "idx_employee_invites_email")
  @@map("employee_invites")
}

model Holiday {
  id              BigInt   @id @default(autoincrement())
  date            DateTime @unique @db.Date
  day             String
  occasion        String
  isDefaultWeekly Boolean  @default(false) @map("is_default_weekly")
  isActive        Boolean  @default(true) @map("is_active")

  @@map("holidays")
}

model Company {
  id          BigInt    @id @default(autoincrement())
  companyName String    @unique @map("company_name")
  email       String    @unique
  contactNo   String    @map("contact_no")
  website     String?
  address     String?
  logoUrl     String?   @map("logo_url")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  @@map("company_settings")
}

model EmergencyContact {
  id           BigInt   @id @default(autoincrement())
  name         String
  email        String
  mobile       String   @map("mobile_number")
  relationship String
  address      String
  employeeId   String   @map("employee_id")
  employee     Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)

  @@map("emergency_contact")
}

model EmployeeDocument {
  id         BigInt   @id @default(autoincrement())
  employeeId String   @map("employee_id")
  bucket     String?
  path       String?
  filename   String
  mime       String?
  size       BigInt?
  url        String
  uploadedBy String?  @map("uploaded_by")
  entityType String   @default("DOCUMENT") @map("entity_type")
  uploadedAt DateTime @default(now()) @map("uploaded_at")
  employee   Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)

  @@map("employee_documents")
}

model Notification {
  id                 BigInt    @id @default(autoincrement())
  senderEmployeeId   String?   @map("sender_employee_id")
  receiverEmployeeId String    @map("receiver_employee_id")
  title              String
  message            String
  type               String?
  readFlag           Boolean   @default(false) @map("read_flag")
  createdAt          DateTime  @default(now()) @map("created_at")
  readAt             DateTime? @map("read_at")
  sender             Employee? @relation("NotificationSender", fields: [senderEmployeeId], references: [employeeId], onDelete: SetNull)
  receiver           Employee  @relation("NotificationReceiver", fields: [receiverEmployeeId], references: [employeeId], onDelete: Cascade)

  @@map("notification")
}

model PushToken {
  id         BigInt    @id @default(autoincrement())
  employeeId String    @map("employee_id")
  provider   String
  token      String    @unique @db.VarChar(500)
  deviceInfo String?   @map("device_info")
  lastSeen   DateTime? @default(now()) @map("last_seen")
  employee   Employee  @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)

  @@index([employeeId], map: "idx_push_tokens_user")
  @@map("push_tokens")
}

model Award {
  id                   BigInt          @id @default(autoincrement())
  title                String
  summary              String?
  isActive             Boolean         @default(true) @map("is_active")
  uploadedByEmployeeId String?         @map("uploaded_by_employee_id")
  iconUrl              String?         @map("icon_url")
  iconObjectKey        String?         @map("icon_object_key")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")
  appreciations        Appreciation[]

  @@map("awards")
}

model Appreciation {
  id                BigInt    @id @default(autoincrement())
  awardId           BigInt    @map("award_id")
  givenToEmployeeId String    @map("given_to_employee_id")
  date              DateTime  @db.Date
  summary           String?
  photoUrl          String?   @map("photo_url")
  photoObjectKey    String?   @map("photo_object_key")
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime? @updatedAt @map("updated_at")
  award             Award     @relation(fields: [awardId], references: [id], onDelete: Cascade)
  givenTo           Employee  @relation(fields: [givenToEmployeeId], references: [employeeId], onDelete: Cascade)

  @@index([givenToEmployeeId], map: "idx_appreciation_employee")
  @@map("appreciations")
}

model Promotion {
  id               BigInt      @id @default(autoincrement())
  employeeId       String      @map("employee_id")
  oldDepartmentId  BigInt      @map("old_department_id")
  oldDesignationId BigInt      @map("old_designation_id")
  newDepartmentId  BigInt      @map("new_department_id")
  newDesignationId BigInt      @map("new_designation_id")
  isPromotion      Boolean     @map("is_promotion")
  sendNotification Boolean     @default(false) @map("send_notification")
  remarks          String?
  createdAt        DateTime    @default(now()) @map("created_at")
  employee         Employee    @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  oldDepartment    Department  @relation("PromotionOldDepartment", fields: [oldDepartmentId], references: [id], onDelete: Restrict)
  oldDesignation   Designation @relation("PromotionOldDesignation", fields: [oldDesignationId], references: [id], onDelete: Restrict)
  newDepartment    Department  @relation("PromotionNewDepartment", fields: [newDepartmentId], references: [id], onDelete: Restrict)
  newDesignation   Designation @relation("PromotionNewDesignation", fields: [newDesignationId], references: [id], onDelete: Restrict)

  @@index([employeeId], map: "idx_promotion_employee")
  @@map("promotions")
}

model Attendance {
  id                  BigInt                @id @default(autoincrement())
  employeeId          String                @map("employee_id")
  date                DateTime              @db.Date
  clockInTime         DateTime?             @map("clock_in_time") @db.Time(0)
  clockInLocation     String?               @map("clock_in_location")
  clockInWorkingFrom  String?               @map("clock_in_working_from")
  clockOutTime        DateTime?             @map("clock_out_time") @db.Time(0)
  clockOutLocation    String?               @map("clock_out_location")
  clockOutWorkingFrom String?               @map("clock_out_working_from")
  late                Boolean               @default(false) @map("is_late")
  halfDay             Boolean               @default(false) @map("is_half_day")
  overwritten         Boolean               @default(false) @map("is_overwritten")
  isPresent           Boolean               @default(true) @map("is_present")
  markedById          String?               @map("marked_by_id")
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")
  employee            Employee              @relation("EmployeeAttendance", fields: [employeeId], references: [employeeId], onDelete: Cascade)
  markedBy            Employee?             @relation("AttendanceMarkedBy", fields: [markedById], references: [employeeId], onDelete: SetNull)
  activities          AttendanceActivity[]

  @@unique([employeeId, date])
  @@map("attendances")
}

model AttendanceActivity {
  id           BigInt      @id @default(autoincrement())
  employeeId   String      @map("employee_id")
  date         DateTime    @db.Date
  type         String
  time         DateTime    @db.Time(0)
  location     String?
  workingFrom  String?     @map("working_from")
  attendanceId BigInt?     @map("attendance_id")
  createdAt    DateTime    @default(now()) @map("created_at")
  employee     Employee    @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  attendance   Attendance? @relation(fields: [attendanceId], references: [id], onDelete: SetNull)

  @@index([employeeId, date], map: "idx_activity_employee_date")
  @@map("attendance_activities")
}

model Leave {
  id              BigInt       @id @default(autoincrement())
  employeeId      String       @map("employee_id")
  leaveType       LeaveType    @map("leave_type")
  durationType    DurationType @map("duration_type")
  startDate       DateTime?    @map("start_date") @db.Date
  endDate         DateTime?    @map("end_date") @db.Date
  singleDate      DateTime?    @map("single_date") @db.Date
  reason          String?
  status          LeaveStatus
  rejectionReason String?      @map("rejection_reason")
  approvedById    String?      @map("approved_by_id")
  approvedAt      DateTime?    @map("approved_at")
  rejectedAt      DateTime?    @map("rejected_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  isPaid          Boolean      @default(false) @map("is_paid")
  employee        Employee     @relation("EmployeeLeaves", fields: [employeeId], references: [employeeId], onDelete: Cascade)
  approvedBy      Employee?    @relation("LeaveApprovedBy", fields: [approvedById], references: [employeeId], onDelete: SetNull)
  documents       LeaveDocument[]

  @@map("leaves")
}

model LeaveDocument {
  id         BigInt   @id @default(autoincrement())
  leaveId     BigInt  @map("leave_id")
  filename    String
  url         String
  mime        String?
  size        BigInt?
  uploadedAt  DateTime @default(now()) @map("uploaded_at")
  leave       Leave   @relation(fields: [leaveId], references: [id], onDelete: Cascade)

  @@map("leave_documents")
}

model LeaveQuota {
  id              BigInt   @id @default(autoincrement())
  employeeId      String   @map("employee_id")
  leaveType       String   @map("leaveType")
  year            Int      @default(2026)
  totalLeaves     Int
  monthlyLimit    Int?
  totalTaken      Int      @default(0)
  overUtilized    Int      @default(0)
  remainingLeaves Int      @default(0)
  employee        Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)

  @@unique([employeeId, leaveType, year])
  @@map("leave_quota")
}
